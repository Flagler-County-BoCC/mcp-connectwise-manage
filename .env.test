NODE_ENV=test

# Minimal ConnectWise credentials for tests (never real values)
CW_server=test.example.com
CW_company=testcompany
CW_clientId=00000000-0000-0000-0000-000000000000
CW_pub=test-public-key-32chars-padding00
CW_priv=test-private-key-32chars-padding0

# Test fixture spec (created by test setup)
SPEC_PATH=tests/fixtures/openapi.json

# API defaults
CW_API_PATH=v4_6_release
CW_TIMEOUT_MS=5000
CW_MAX_CONCURRENCY=2
CW_HEADERS_ALLOWLIST=Accept

# Minimal module exposure for tests
CW_ENABLED_MODULES=service,time
CW_ALLOWED_OPERATIONS=[]
CW_WRITE_ALLOWLIST=[]

# Profiles
CW_PROFILES={"admin":[""]}
CW_ACTIVE_PROFILE=admin

# Safe defaults
CW_DEFAULT_SERVICE_BOARD=Test Board
CW_DEFAULT_SERVICE_DEPARTMENT=Test Department
CW_DEFAULT_COMPANY_SCOPE=All Companies
CW_DEFAULT_PAGE_SIZE=10
CW_MAX_PAGE_SIZE=50
CW_DEFAULT_TIME_WINDOW_DAYS=7
CW_TOTAL_ROWS_LIMIT=100

# Write safeguards
CW_REQUIRE_CONFIRM_WRITES=true
CW_ENABLE_DRY_RUN=true
CW_BLACKOUT_WINDOWS=[]

# Rate limiting (relaxed for tests)
CW_RATE_LIMIT_BURST_RPS=100
CW_RATE_LIMIT_SUSTAINED_RPM=6000

# Logging
LOG_LEVEL=silent
