# ─── ConnectWise API credentials (required) ──────────────────────────────────
CW_server=na.connectwise.com
CW_company=yourCompanyName
CW_clientId=00000000-0000-0000-0000-000000000000
CW_pub=CHANGE_ME
CW_priv=CHANGE_ME

# Absolute path to your ConnectWise OpenAPI 3.0 JSON spec (required)
SPEC_PATH=/absolute/path/to/openapi.json

# ─── API configuration ────────────────────────────────────────────────────────
CW_API_PATH=v4_6_release
CW_TIMEOUT_MS=30000
CW_MAX_CONCURRENCY=5
CW_HEADERS_ALLOWLIST=Accept

# ─── Module exposure & operation allowlists ───────────────────────────────────
CW_ENABLED_MODULES=service,time,agreements,companies,projects,sales,setup
CW_ALLOWED_OPERATIONS=[{"method":"get","pathPattern":"^/service/tickets$"},{"method":"get","pathPattern":"^/service/boards$"},{"method":"get","pathPattern":"^/time/entries$"}]
CW_WRITE_ALLOWLIST=[{"method":"post","pathPattern":"^/time/entries$"},{"method":"patch","pathPattern":"^/time/entries/[^/]+$"}]

# ─── Profile-based tool filtering ────────────────────────────────────────────
CW_PROFILES={"technician":["svc-","time-","prj-","co-","setup-"],"billing":["time-","agr-","co-","sal-","setup-"],"procurement":["co-","sal-","setup-"],"admin":[""]}
CW_ACTIVE_PROFILE=technician

# ─── Safe defaults ────────────────────────────────────────────────────────────
CW_DEFAULT_SERVICE_BOARD=Managed Services
CW_DEFAULT_SERVICE_DEPARTMENT=Managed Services
CW_DEFAULT_COMPANY_SCOPE=All Companies
CW_DEFAULT_PAGE_SIZE=50
CW_MAX_PAGE_SIZE=100
CW_DEFAULT_TIME_WINDOW_DAYS=30
CW_TOTAL_ROWS_LIMIT=500

# ─── Write safeguards ─────────────────────────────────────────────────────────
CW_REQUIRE_CONFIRM_WRITES=true
CW_ENABLE_DRY_RUN=true
CW_BLACKOUT_WINDOWS=[]

# ─── Rate limiting ────────────────────────────────────────────────────────────
CW_RATE_LIMIT_BURST_RPS=5
CW_RATE_LIMIT_SUSTAINED_RPM=60

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
